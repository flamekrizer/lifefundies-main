rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow any authenticated user (email / google / anonymous)
    match /users/{userId} {
      allow read: if request.auth != null
                  && (
                    request.auth.uid == userId ||
                    resource.data.role == 'mentor'
                  );
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // Guides - Public read, admin write (for now, allow all for testing)
    match /guides/{guideId} {
      allow read: if true; // Anyone can read guides
      allow write: if true; // TODO: Restrict to admin only in production
      
      // Slots sub-collection
      match /slots/{slotId} {
        allow read: if true; // Anyone can see available slots
        allow write: if true; // TODO: Restrict to admin/guide only in production
      }
    }

    // Top-level guide_slots collection
    match /guide_slots/{slotId} {
      allow read: if true; // Anyone can see available slots
      allow write: if true; // TODO: Restrict in production
    }

    // Bookings - User can read their own, write to create
    match /bookings/{bookingId} {
      allow read: if request.auth != null && 
                  (request.auth.uid == resource.data.userId || 
                   request.auth.uid == resource.data.guideId);
      allow create: if request.auth != null && 
                    request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null;
    }

    // Sessions - User and guide can read/write their sessions
    match /sessions/{sessionId} {
      allow read: if request.auth != null &&
                  (request.auth.uid == resource.data.userId || 
                   request.auth.uid == resource.data.guideId);
      allow write: if request.auth != null;
      
      // Messages sub-collection
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }

    // Payments - User can read their own payments
    match /payments/{paymentId} {
      allow read: if request.auth != null && 
                  request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Notifications - User can read their own
    match /notifications/{notificationId} {
      allow read: if request.auth != null && 
                  request.auth.uid == resource.data.userId;
      allow create: if true; // System can create notifications
      allow update: if request.auth != null &&
                    request.auth.uid == resource.data.userId &&
                    request.resource.data.userId == resource.data.userId;
    }

    // Community forum - public read, authenticated write.
    // Authenticated includes Firebase anonymous users.
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;
    }

    match /community_comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;
    }

    // Mentor reviews - public read, authenticated write.
    match /mentor_reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.sessionId is string
                    && exists(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId))
                    && get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.status == 'completed'
                    && get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.userId == request.auth.uid
                    && get(/databases/$(database)/documents/sessions/$(request.resource.data.sessionId)).data.guideId == request.resource.data.mentorId;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

  }
}
